{
  "name": "proyecto-rutaexpress",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "start": "npm --prefix client start",
    "server": "node --env-file=.env server/index.js",
    "dev": "concurrently \"npm --prefix client start\" \"npm run server\"",
    "build": "npm --prefix client run build",
    "test": "npm --prefix client test",
    "audit": "npm audit fix --prefix client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
