{
	"name": "server",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "npx esbuild index.js --bundle --platform=node --format=esm --outfile=dist/index.js --minify",
		"start": "node --env-file=../.env dist/index.js",
		"dev": "node --watch --env-file=../.env index.js"
	},
	"dependencies": {
		"bcryptjs": "3.0.3",
		"cors": "2.8.6",
		"express": "5.2.1",
		"mongoose": "9.7.3"
	},
	"devDependencies": {
		"esbuild": "0.25.12"
	}
}
